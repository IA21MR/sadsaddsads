{
  "projectTypes": [
    {
      "id": "public_website",
      "label": "Sitio web público",
      "shortLabel": "Sitio público",
      "description": "Proyecto sin login, enfocado en presencia pública y conversión.",
      "helper": "Formulario de reservas conectado a backend real con PostgreSQL.",
      "requiresAuth": false,
      "defaultArchitecture": "frontend_with_backend",
      "defaultCapabilities": ["reservations", "lead_capture"]
    },
    {
      "id": "private_software",
      "label": "Software o sistema privado",
      "shortLabel": "Software privado",
      "description": "Proyecto con login, dashboard y módulos internos para operación del cliente.",
      "helper": "Incluye auth, usuarios, roles y permite crecer hacia ERP, reservas, ventas o reportes.",
      "requiresAuth": true,
      "defaultArchitecture": "private_fullstack",
      "defaultCapabilities": ["dashboard", "auth", "users", "roles", "permissions"]
    }
  ],
  "modules": [
    {
      "id": "reservations",
      "kind": "module",
      "label": "Reservas simples",
      "description": "Reservas simples sin zona privada de administración avanzada.",
      "supportedProjectTypes": ["public_website"],
      "requiresBackend": true,
      "requiresDatabase": true,
      "requiresAuth": false,
      "isCore": false,
      "dependencies": [],
      "category": "public",
      "routePath": "/reservations",
      "generatedPageType": "reservations",
      "capabilities": ["reservations", "lead_capture"]
    },
    {
      "id": "reservas-whatsapp",
      "kind": "extension",
      "extends": "reservations",
      "label": "Confirmaciones por WhatsApp",
      "description": "Envía confirmaciones automáticas cuando se crea una reserva.",
      "supportedProjectTypes": ["public_website"],
      "requiresBackend": true,
      "requiresDatabase": true,
      "requiresAuth": false,
      "isCore": false,
      "dependencies": ["reservations"],
      "category": "public",
      "capabilities": ["whatsapp", "reservation_notifications"],
      "packageName": "@sotek/erp-extension-reservas-whatsapp",
      "packageVersion": "1.0.0",
      "configuration": [
        {
          "key": "confirmationTemplate",
          "label": "Plantilla de confirmación",
          "type": "string",
          "required": true,
          "defaultValue": "Tu reserva para {{date}} ha sido confirmada."
        },
        {
          "key": "accessToken",
          "label": "Access token de WhatsApp",
          "type": "secret",
          "required": true,
          "envVar": "WHATSAPP_ACCESS_TOKEN"
        },
        {
          "key": "phoneNumberId",
          "label": "ID del número de WhatsApp",
          "type": "secret",
          "required": true,
          "envVar": "WHATSAPP_PHONE_NUMBER_ID"
        }
      ]
    },
    {
      "id": "auth",
      "label": "Autenticación",
      "description": "Autenticación, JWT, rate limiting y recuperación de contraseña.",
      "supportedProjectTypes": ["private_software"],
      "requiresBackend": true,
      "requiresDatabase": true,
      "requiresAuth": true,
      "isCore": true,
      "dependencies": ["users"],
      "category": "core",
      "routePath": "/login",
      "generatedPageType": "private_auth",
      "capabilities": ["auth", "sessions"]
    },
    {
      "id": "users",
      "label": "Usuarios",
      "description": "Usuarios, roles y permisos del sistema.",
      "supportedProjectTypes": ["private_software"],
      "requiresBackend": true,
      "requiresDatabase": true,
      "requiresAuth": true,
      "isCore": true,
      "dependencies": [],
      "category": "core",
      "routePath": "/users",
      "generatedPageType": "private_module",
      "capabilities": ["users", "roles", "permissions"]
    },
    {
      "id": "roles",
      "label": "Roles",
      "description": "Gestión de roles del sistema privado.",
      "supportedProjectTypes": ["private_software"],
      "requiresBackend": true,
      "requiresDatabase": true,
      "requiresAuth": true,
      "isCore": true,
      "dependencies": ["users"],
      "category": "core",
      "routePath": "/roles",
      "generatedPageType": "private_module",
      "capabilities": ["roles", "rbac"]
    },
    {
      "id": "permissions",
      "label": "Permisos",
      "description": "Definiciones y asignación de permisos para RBAC.",
      "supportedProjectTypes": ["private_software"],
      "requiresBackend": true,
      "requiresDatabase": true,
      "requiresAuth": true,
      "isCore": true,
      "dependencies": ["users"],
      "category": "core",
      "routePath": "/roles",
      "generatedPageType": "private_module",
      "capabilities": ["permissions", "rbac"]
    },
    {
      "id": "organizations",
      "label": "Organizaciones",
      "description": "Organizaciones y soporte multi-tenant opcional.",
      "supportedProjectTypes": ["private_software"],
      "requiresBackend": true,
      "requiresDatabase": true,
      "requiresAuth": true,
      "isCore": false,
      "dependencies": ["users"],
      "category": "private",
      "routePath": "/organizations",
      "generatedPageType": "private_module",
      "capabilities": ["organizations", "multi_tenant"]
    },
    {
      "id": "contacts",
      "label": "Contactos",
      "description": "Gestión interna de contactos y clientes.",
      "supportedProjectTypes": ["private_software"],
      "requiresBackend": true,
      "requiresDatabase": true,
      "requiresAuth": true,
      "isCore": false,
      "dependencies": ["users"],
      "category": "private",
      "routePath": "/contacts",
      "generatedPageType": "private_module",
      "capabilities": ["crm", "contacts"]
    }
  ],
  "scaffold": {
    "publicWebsite": {
      "excludedPrefixes": [
        ".agents/",
        ".codex/",
        "app/src/infrastructure/",
        "app/src/modules/",
        "app/src/shared/",
        "app/scripts/",
        "app/src/shared/plugin-system/",
        "app/test/",
        "app/prisma/migrations/",
        "app/prisma/seeds/",
        "cli/",
        "docs/",
        "web/src/app/(dashboard)/",
        "web/src/app/login/",
        "web/src/app/reset-password/",
        "web/src/modules/admin/",
        "web/src/modules/auth/",
        "web/src/modules/",
        "web/src/modules/organizations/",
        "web/src/modules/users/",
        "web/src/shared/",
        "web/src/shared/presentation/layout/",
        "web/src/shared/presentation/navigation/",
        "web/src/shared/plugin-system/__tests__/",
        "web/src/lib/",
        "web/src/test/",
        "web/e2e/",
        "web/playwright/",
        "web/playwright.config.ts"
      ],
      "excludedFiles": [
        "app/prisma/permissions.mjs",
        "app/src/shared/domain/PermissionDefinition.ts",
        "app/src/shared/domain/rules/PermissionDependencyRules.ts",
        "app/src/shared/infrastructure/decorators/module-access.decorator.ts",
        "app/src/shared/infrastructure/decorators/require-permissions.decorator.ts",
        "app/src/shared/infrastructure/guards/PermissionsGuard.ts",
        "web/src/shared/domain/rules/PermissionDependencyRules.ts",
        "web/src/shared/infrastructure/http/api-client.ts",
        "web/src/shared/presentation/components/AuthGuard.tsx",
        "web/src/shared/presentation/components/ModuleGuard.tsx",
        "web/src/shared/presentation/components/PermissionButton.tsx",
        "web/src/shared/presentation/components/SessionExpirationWarning.tsx",
        "web/src/shared/presentation/components/TokenSyncProvider.tsx",
        "web/src/shared/presentation/hooks/useCurrentOrgModules.ts",
        "web/src/shared/presentation/hooks/useTokenSync.ts",
        "web/src/lib/doTokenStore.ts",
        "web/src/lib/githubTokenStore.ts"
      ]
    }
  }
}
