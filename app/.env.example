# Database
POSTGRES_USER=erp
POSTGRES_PASSWORD=erp123
POSTGRES_DB=sotek
DATABASE_URL="postgresql://erp:erp123@localhost:5433/sotek?schema=public"
ERP_PLATFORM_MODE=true

# App
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=dev-jwt-secret-change-me-minimum-32-chars
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-minimum-32-chars
JWT_ACCESS_TOKEN_EXPIRATION=15m
JWT_REFRESH_TOKEN_EXPIRATION=7d

# Auth policy
MAX_LOGIN_ATTEMPTS=5
LOCK_DURATION_MINUTES=15
RESET_CODE_TTL_MINUTES=15

# Rate limit
RATE_LIMIT_MAX=100
RATE_LIMIT_TTL=60000

# CORS
CORS_ORIGINS=http://localhost:3001

# Plugin system
# Activar para permitir plugins externos instalados como paquetes npm.
# Requerido para que create-erp install funcione en runtime.
ERP_EXTERNAL_PLUGINS=0
